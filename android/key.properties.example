# Copy to android/key.properties and fill in real values.
# key.properties and *.jks / *.keystore must NOT be committed.
#
# Generate a keystore (from repo root):
#   ./tool/create_release_keystore.sh

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=fitnessplan
storeFile=upload-keystore.jks
